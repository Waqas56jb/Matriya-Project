{
  "name": "matriya-rag-backend",
  "version": "1.0.0",
  "description": "MATRIYA RAG System API - Node.js Backend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "npm run test:unit",
    "test:unit": "npm run check:pre-llm-gate && npm run check:attribution-document-flow && npm run verify:david-three && npm run verify:chai-scope && npm run check:retrieval-threshold && npm run check:answer-binding && npm run check:answer-composer && npm run verify:lab-answer-efficacy && npm run verify:lab-constraint-rules && npm run verify:ism001-experiment-plan && npm run test:delete-guard && npm run verify:scope-signoff && npm run verify:david-checklist",
    "check:answer-composer": "node scripts/check-answer-composer.js",
    "verify:lab-constraint-rules": "node scripts/verify-lab-constraint-rules.js",
    "verify:lab-answer-efficacy": "node scripts/verifyLabAnswerEfficacyText.js",
    "verify:ism001-experiment-plan": "node scripts/verify-ism001-experiment-plan.js",
    "demo:ism001-experiment-plan": "node scripts/demo-ism001-experiment-plan.js",
    "verify:constraint-engine": "node scripts/verifyConstraintEngine.js",
    "verify:scope-signoff": "node scripts/verify-scope-signoff.mjs",
    "verify:david-checklist": "node scripts/verify-david-checklist.mjs",
    "test:integration": "npm run check:task3 && npm run check:task4 && npm run check:task5 && npm run check:task6 && npm run check:task7 && npm run check:task8 && npm run check:task2 && npm run check:dashboard",
    "test:live": "node scripts/run-test-live.mjs",
    "check:task3": "node scripts/check-snapshots.js",
    "check:task4": "node scripts/check-global-metrics.js",
    "check:task5": "node scripts/check-recovery-improved.js",
    "check:task6": "node scripts/check-justification-templates.js",
    "check:task7": "node scripts/check-doe-integration.js",
    "check:task8": "node scripts/check-risk-oracle.js",
    "check:task2": "node scripts/check-integrity-rules-engine.js",
    "check:dashboard": "node scripts/check-dashboard-improvements.js",
    "check:pre-llm-gate": "node -r dotenv/config scripts/check-pre-llm-gate.js",
    "check:attribution-document-flow": "node -r dotenv/config scripts/check-attribution-and-document-flow.js",
    "test:ask-matriya-david": "node scripts/run-ask-matriya-david-tests.mjs",
    "verify:david-three": "node scripts/print-and-verify-david-three-tests.mjs",
    "verify:chai-scope": "node scripts/verify-chai-scope.mjs",
    "check:retrieval-threshold": "node -r dotenv/config scripts/check-retrieval-similarity-filter.js",
    "check:answer-binding": "node scripts/check-answer-binding-filter.js",
    "test:delete-guard": "node scripts/test-delete-snippet-guard.mjs",
    "apply:external-layer": "node scripts/applyExternalLayerPhase1.js --seed",
    "verify:external-layer-phase1": "node scripts/verifyExternalLayerPhase1.js",
    "verify:external-layer-isolation": "node scripts/verifyExternalLayerIsolation.js",
    "verify:external-layer-all": "node scripts/verifyExternalLayerIsolation.js && node scripts/verifyExternalLayerPhase1.js",
    "cron:external-layer-freshness": "node scripts/externalLayerFreshnessCron.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.1",
    "pgvector": "^0.1.3",
    "sequelize": "^6.35.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
